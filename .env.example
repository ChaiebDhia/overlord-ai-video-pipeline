# .env.example

# ✅ SOLUTIONS GRATUITES (Recommandé, pas de carte bleue)
GROQ_API_KEY=gsk_votre_cle_groq    # Pour LLM + Sous-titres (https://console.groq.com/keys)
ELEVENLABS_API_KEY=sk_votre_cle_ee # Pour la Voix (https://elevenlabs.io/)

# 💰 SOLUTIONS PAYANTES (Facturation requise)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_AI_API_KEY=your-google-ai-key-here

# Configuration
LLM_PROVIDER=openai          # Laissez "openai" car Groq simule OpenAI !
TTS_PROVIDER=openai          # Laissez la logique faire le fallback sur ElevenLabs
TTS_VOICE=onyx               # onyx | fable | alloy | echo | nova | shimmer
OUTPUT_DIR=./output
DEFAULT_LANGUAGE=fr